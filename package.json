{
  "name": "cosmicsphere",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "install:ci": "bash scripts/install-ci.sh",
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vite",
    "build": "bash scripts/build-verified.sh",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run test:unit && npm run build && node --test tests/rendered-html.test.mjs",
    "test:unit": "node --experimental-strip-types --test tests/timezone.test.ts tests/engine-reference.test.ts tests/reference-chart-certification.test.ts tests/interpretation-evidence.test.ts tests/interpretation-rule-packs.test.ts tests/ask-my-chart.test.ts tests/premium-report.test.ts tests/account-vault.test.ts tests/billing.test.ts tests/professional-dashboard.test.ts tests/claim-integrity.test.mjs tests/migration-drift.test.mjs tests/ci-workflow.test.mjs",
    "validate:artifact": "bash scripts/validate-artifact.sh",
    "lint": "bash scripts/sites-env.sh -- eslint . --ignore-pattern dist --ignore-pattern .next",
    "typecheck": "bash scripts/sites-env.sh -- tsc --noEmit --pretty false",
    "db:generate": "bash scripts/sites-env.sh -- drizzle-kit generate",
    "db:validate": "node scripts/validate-migrations.mjs",
    "db:baseline": "node scripts/validate-migrations.mjs --write"
  },
  "dependencies": {
    "@photostructure/tz-lookup": "11.6.0",
    "astronomy-engine": "2.1.19",
    "drizzle-orm": "0.45.2",
    "moment-timezone": "0.6.3",
    "next": "16.2.6",
    "pdf-lib": "1.17.1",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module",
  "displayName": "Celestial ASTRO AI"
}
